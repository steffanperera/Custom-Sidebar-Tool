{
  "name": "custom-sidebar-tool",
  "displayName": "custom-sidebar-tool",
  "description": "custom sidebar tool",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:customSidebar.selectExplorerIcon"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "customSidebar.selectExplorerIcon",
        "title": "Select Custom Explorer Icon"
      },
      {
        "command": "customSidebar.resetExplorerIcon",
        "title": "Reset Explorer Icon to Default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mySidebar",
          "title": "Custom Icon Tool",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "mySidebar": [
        {
          "id": "mySidebarView",
          "name": "Explorer Icon Customizer"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.52.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
